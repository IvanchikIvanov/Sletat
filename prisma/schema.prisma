generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

model User {
  id              String          @id @default(cuid())
  telegramId      String          @unique
  username        String?
  firstName       String?
  lastName        String?
  languageCode    String?
  defaultCountry  String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  searchProfiles  SearchProfile[]
  searchRequests  SearchRequest[]
  subscriptions   Subscription[]
  notificationLog NotificationLog[]
  bookings        Booking[]
  preferences     UserPreference[]
  facts           UserFact[]
}

model SearchProfile {
  id                 String        @id @default(cuid())
  userId             String
  name               String
  departureCityCode  String?
  countryCode        String?
  resortCode         String?
  hotelCategory      String?
  mealCode           String?
  adults             Int?
  children           Int?
  childrenAges       Json?
  dateFrom           DateTime?
  dateTo             DateTime?
  nightsFrom         Int?
  nightsTo           Int?
  budgetMin          Int?
  budgetMax          Int?
  currency           String?       @default("RUB")
  isActive           Boolean       @default(true)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  user         User           @relation(fields: [userId], references: [id])
  searchRequests SearchRequest[]
  searchResults  SearchResult[]
  subscriptions  Subscription[]
  bookings       Booking[]
}

model SearchRequest {
  id          String               @id @default(cuid())
  userId      String
  profileId   String?
  rawText     String
  parsedJson  Json?
  status      SearchRequestStatus  @default(PENDING)
  errorMessage String?
  createdAt   DateTime             @default(now())

  user    User          @relation(fields: [userId], references: [id])
  profile SearchProfile? @relation(fields: [profileId], references: [id])
}

model SearchResult {
  id              String         @id @default(cuid())
  profileId       String
  externalOfferId String
  hotelName       String?
  countryName     String?
  resortName      String?
  mealName        String?
  roomName        String?
  departureCity   String?
  dateFrom        DateTime?
  dateTo          DateTime?
  nights          Int?
  price           Int
  currency        String         @default("RUB")
  isActive        Boolean        @default(true)
  foundAt         DateTime       @default(now())

  profile        SearchProfile   @relation(fields: [profileId], references: [id])
  subscriptions  Subscription[]  @relation("SubscriptionLatestResult")
  notificationLog NotificationLog[]
  bookings       Booking[]

  @@index([profileId])
  @@index([externalOfferId])
}

model Subscription {
  id                       String           @id @default(cuid())
  profileId                String
  userId                   String
  minPrice                 Int?
  maxPrice                 Int?
  priceDropThresholdPercent Int              @default(15)
  maxNotificationsPerDay   Int              @default(5)
  isActive                 Boolean          @default(true)
  createdAt                DateTime         @default(now())
  updatedAt                DateTime         @updatedAt

  profile          SearchProfile   @relation(fields: [profileId], references: [id])
  user             User            @relation(fields: [userId], references: [id])
  latestResult     SearchResult?   @relation("SubscriptionLatestResult", fields: [latestResultId], references: [id])
  latestResultId   String?
  notificationLog  NotificationLog[]

  @@index([profileId])
  @@index([userId])
  @@unique([profileId, userId])
}

model NotificationLog {
  id             String              @id @default(cuid())
  subscriptionId String
  searchResultId String
  userId         String
  sentAt         DateTime            @default(now())
  priceAtSend    Int
  reason         NotificationReason

  subscription Subscription  @relation(fields: [subscriptionId], references: [id])
  searchResult SearchResult  @relation(fields: [searchResultId], references: [id])
  user         User          @relation(fields: [userId], references: [id])

  @@index([subscriptionId])
  @@index([searchResultId])
  @@index([userId])
}

model Booking {
  id             String         @id @default(cuid())
  userId         String
  profileId      String?
  searchResultId String
  claimId        String?
  status         BookingStatus  @default(PENDING)
  lastError      String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  user    User          @relation(fields: [userId], references: [id])
  profile SearchProfile? @relation(fields: [profileId], references: [id])
  result  SearchResult  @relation(fields: [searchResultId], references: [id])

  @@index([userId])
  @@index([profileId])
  @@index([searchResultId])
}

enum SearchRequestStatus {
  PENDING
  SUCCESS
  FAILED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  FAILED
}

enum NotificationReason {
  PRICE_DROP
  NEW_IN_BUDGET
}

model UserPreference {
  id        String                    @id @default(cuid())
  userId    String
  text      String
  embedding Unsupported("vector(1536)")?
  category  String                    @default("search")
  metadata  Json?
  createdAt DateTime                  @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Knowledge {
  id          String                    @id @default(cuid())
  text        String
  embedding   Unsupported("vector(1536)")?
  category    String                    @default("tourism")
  subcategory String?
  source      String                    @default("web")
  sourceUrl   String?
  metadata    Json?
  expiresAt   DateTime?
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt

  @@index([category])
  @@index([category, subcategory])
}

model UserFact {
  id         String                      @id @default(cuid())
  userId     String
  fact       String
  category   String
  key        String?
  embedding  Unsupported("vector(1536)")?
  confidence Float                       @default(1.0)
  source     String                      @default("dialog")
  createdAt  DateTime                    @default(now())
  updatedAt  DateTime                    @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, key])
  @@index([userId])
  @@index([category])
}

// ─── Sletat справочники (кэш) ───

model CachedCountry {
  id           String   @id
  name         String
  alias        String?
  isVisa       Boolean  @default(false)
  flags        Int      @default(0)
  rank         Int      @default(0)
  townFromId   Int      @default(832)
  fetchedAt    DateTime @default(now())

  resorts      CachedResort[]
  hotels       CachedHotel[]
  hotDeals     CachedHotDeal[]

  @@unique([id, townFromId])
  @@index([townFromId])
  @@index([name])
}

model CachedResort {
  id          String   @id
  name        String
  countryId   String
  isPopular   Boolean  @default(false)
  parentId    String?
  fetchedAt   DateTime @default(now())

  country     CachedCountry @relation(fields: [countryId], references: [id], onDelete: Cascade)
  hotels      CachedHotel[]

  @@index([countryId])
  @@index([name])
}

model CachedHotel {
  id          String   @id
  name        String
  countryId   String
  resortId    String?
  starId      String?
  starName    String?
  rating      Float?
  photosCount Int      @default(0)
  fetchedAt   DateTime @default(now())

  country     CachedCountry @relation(fields: [countryId], references: [id], onDelete: Cascade)
  resort      CachedResort? @relation(fields: [resortId], references: [id], onDelete: SetNull)

  @@index([countryId])
  @@index([resortId])
  @@index([name])
  @@index([starName])
}

model CachedHotDeal {
  id            String   @id @default(cuid())
  countryId     String
  countryName   String
  hotelName     String?
  starName      String?
  resortName    String?
  mealName      String?
  minPrice      Int
  currency      String   @default("RUB")
  minPriceDate  String?
  nights        Int?
  offerId       String?
  townFromId    Int      @default(832)
  fetchedAt     DateTime @default(now())

  country       CachedCountry @relation(fields: [countryId], references: [id], onDelete: Cascade)

  @@index([countryId])
  @@index([townFromId])
  @@index([fetchedAt])
}

model CachedDepartureCity {
  id          String   @id
  name        String
  countryId   String?
  isDefault   Boolean  @default(false)
  isPopular   Boolean  @default(false)
  fetchedAt   DateTime @default(now())

  @@index([name])
}

model CachedMeal {
  id          String   @id
  name        String
  fetchedAt   DateTime @default(now())
}

