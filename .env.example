NODE_ENV=development
PORT=3000
PUBLIC_BASE_URL=http://localhost:3000

TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_USE_POLLING=true

OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
OPENAI_PROXY_URL=

SLETAT_LOGIN=your-sletat-login
SLETAT_PASSWORD=your-sletat-password
SLETAT_SEARCH_BASE_URL=https://module.sletat.ru/Main.svc
SLETAT_CLAIMS_BASE_URL=https://module.sletat.ru/Main.svc

SLETAT_MODE=api
SLETAT_PROTOCOL=json
SLETAT_CLAIMS_PROTOCOL=json

SLETAT_ENDPOINT_DEPARTURE_CITIES=GetDepartCities
SLETAT_ENDPOINT_COUNTRIES=GetCountries
SLETAT_ENDPOINT_MEALS=GetMeals
SLETAT_ENDPOINT_HOTELS=GetHotels
SLETAT_ENDPOINT_SEARCH=GetTours
SLETAT_ENDPOINT_ACTUALIZE=ActualizePrice
SLETAT_ENDPOINT_CLAIM_CREATE=SaveTourOrder
SLETAT_ENDPOINT_CLAIM_INFO=GetClaimInfo
SLETAT_ENDPOINT_PAYMENTS=GetPayments

DATABASE_URL=postgresql://user:password@postgres:5432/sletat_bot?schema=public
REDIS_URL=redis://redis:6379

MONITORING_INTERVAL_MS=900000

