NODE_ENV=development
PORT=3000
PUBLIC_BASE_URL=http://localhost:3000

TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_USE_POLLING=true

OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe

SLETAT_LOGIN=your-sletat-login
SLETAT_PASSWORD=your-sletat-password
SLETAT_SEARCH_BASE_URL=https://api.sletat.ru/search
SLETAT_CLAIMS_BASE_URL=https://api.sletat.ru/claims

DATABASE_URL=postgresql://user:password@postgres:5432/sletat_bot?schema=public
REDIS_URL=redis://redis:6379

MONITORING_INTERVAL_MS=900000

