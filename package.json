{
  "name": "sletat-telegram-bot",
  "version": "1.0.0",
  "description": "Telegram-бот для поиска и мониторинга туров Sletat на NestJS",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "start:dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "lint": "echo \"no lint configured\""
  },
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/config": "^3.0.0",
    "@nestjs/bull": "^10.0.0",
    "bull": "^4.12.0",
    "ioredis": "^5.4.1",
    "nestjs-telegraf": "^2.8.0",
    "telegraf": "^4.16.0",
    "openai": "^4.52.0",
    "https-proxy-agent": "^7.0.6",
    "joi": "^17.13.3",
    "@prisma/client": "5.15.0",
    "rxjs": "^7.8.1",
    "reflect-metadata": "^0.2.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "@types/node": "^22.7.4",
    "prisma": "5.15.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
